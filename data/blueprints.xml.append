<crewBlueprint name="jubjub">
	<desc>The Dinosaur Ambassador to the Moon (and subsequently the USSR).</desc>
	<title>Dinorsaur</title>
	<short>Dino</short>
	<cost>750</cost>
	<rarity>0</rarity>
	<powerList>
		<power>Clone-Ready: His DNA has been extensively analysed and he can be cloned at 2x speed. </power>
		<power>Soup: Regains all of his HP upon drinking a speical Soup made by the Soup Dragon.</power>
	</powerList>
	<colorList>
		<layer>
			<color r="95" g="102" b="116" a="0.1" />
			<color r="26" g="26" b="26" a="0.3" />
			<color r="177" g="194" b="201" a="0.1" />
			<color r="41" g="67" b="129" a="0.2" />
			<color r="66" g="73" b="77" a="0.3" />
			<color r="54" g="55" b="77" a="0.2" />
			<color r="20" g="43" b="73" a="0.3" />
			<color r="0" g="38" b="90" a="0.2" />
			<color r="159" g="35" b="0" a="0.2" />
			<color r="105" g="13" b="13" a="0.3" />
			<color r="14" g="52" b="15" a="0.3" />
			<color r="67" g="50" b="129" a="0.3" />
		</layer>
	</colorList>
</crewBlueprint>



