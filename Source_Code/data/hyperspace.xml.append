<!-- 
///////////////////////////////////////////////////////////////////////////////////////////////////////
///////////////////////////////////////////////////////////////////////////////////////////////////////
///////////////////////////////////////////////////////////////////////////////////////////////////////
///////////////////////////////////////////////////////////////////////////////////////////////////////
					
					Ships
					
///////////////////////////////////////////////////////////////////////////////////////////////////////
///////////////////////////////////////////////////////////////////////////////////////////////////////
///////////////////////////////////////////////////////////////////////////////////////////////////////
///////////////////////////////////////////////////////////////////////////////////////////////////////
-->

<mod:findLike type="ships">
    <mod-append:ship name="PLAYER_SHIP_SOVIET_LUNAR" b="false" c="false">
		<unlock variant="a" silent="false">
			<type>4</type>
		</unlock>
	</mod-append:ship>
    <mod:findLike type="shipOrder">
        <mod-append:ship>PLAYER_SHIP_SOVIET_LUNAR</mod-append:ship>
    </mod:findLike>
    <mod-append:customShip name="PLAYER_SHIP_SOVIET_LUNAR">
        <hiddenAug>SHIP_MULTIVERSE</hiddenAug>
        <hiddenAug>FOR_MULTIVERSE</hiddenAug>
        <systemLimit>8</systemLimit>
		<crewLimit>8</crewLimit>
        <customReactor maxLevel="25"/>
    </mod-append:customShip>
</mod:findName>

<!-- 
///////////////////////////////////////////////////////////////////////////////////////////////////////					
					Dinosaur Space Ship				
///////////////////////////////////////////////////////////////////////////////////////////////////////
-->

<mod:findLike type="ships">

    <mod-append:ship name="PLAYER_SHIP_DINOSAUR_SPACE_SHIP" b="true" c="false" secret="true">
		<unlock variant="a" silent="false">
			<type>4</type>
		</unlock>
		<unlock variant="b" silent="false">
			<type>1</type>
			<shipReq>PLAYER_SHIP_DINOSAUR_SPACE_SHIP</shipReq>
			<value>5</value>
		</unlock>
		<!-- <unlock variant="c" silent="false">
			<type>1</type>
			<shipReq>PLAYER_SHIP_DINOSAUR_SPACE_SHIP_2</shipReq>
			<value>5</value>
		</unlock>
		<unlock variant="c" silent="false">
			<type>2</type>
			<shipReq>PLAYER_SHIP_DINOSAUR_SPACE_SHIP</shipReq>
		</unlock> -->
	</mod-append:Ship>

    <mod:findLike type="shipOrder">
        <mod-append:ship>PLAYER_SHIP_DINOSAUR_SPACE_SHIP</mod-append:ship>
    </mod:findLike>

    <mod-append:customShip name="PLAYER_SHIP_DINOSAUR_SPACE_SHIP">
        <hiddenAug>SHIP_MULTIVERSE</hiddenAug>
        <hiddenAug>FOR_MULTIVERSE</hiddenAug>
        <systemLimit>8</systemLimit>
		<crewLimit>8</crewLimit>
        <customReactor maxLevel="30"/>
		<crew>
			<jubjub room="0" name="JubJub"/>  <!--piloting-->
			<human room="2" name="Lil' Dog"/> <!--shields-->
		</crew>
    </mod-append:customShip>

	<mod-append:customShip name="PLAYER_SHIP_DINOSAUR_SPACE_SHIP_2">
        <hiddenAug>SHIP_MULTIVERSE</hiddenAug>
        <hiddenAug>FOR_MULTIVERSE</hiddenAug>
        <systemLimit>8</systemLimit>
		<crewLimit>8</crewLimit>
        <customReactor maxLevel="30"/>
		<crew>
			<jubjub room="0" name="Captain Teggs"/>  <!--piloting-->
			<human room="2"/> <!--shields-->
		</crew>
    </mod-append:customShip>


	<mod-append:customShip name="PLAYER_SHIP_DINOSAUR_SPACE_SHIP_3">
        <hiddenAug>SHIP_MULTIVERSE</hiddenAug>
        <hiddenAug>FOR_MULTIVERSE</hiddenAug>
        <systemLimit>8</systemLimit>
		<crewLimit>8</crewLimit>
        <customReactor maxLevel="30"/>
		<crew>
			<crab room="0" name="Crab"/>  <!--piloting-->
			<horse room="2" name="Albert"/> <!--shields-->
		</crew>
    </mod-append:customShip>


</mod:findName>



<!-- 
///////////////////////////////////////////////////////////////////////////////////////////////////////
///////////////////////////////////////////////////////////////////////////////////////////////////////
///////////////////////////////////////////////////////////////////////////////////////////////////////
///////////////////////////////////////////////////////////////////////////////////////////////////////
					
					Crew
					
///////////////////////////////////////////////////////////////////////////////////////////////////////
///////////////////////////////////////////////////////////////////////////////////////////////////////
///////////////////////////////////////////////////////////////////////////////////////////////////////
///////////////////////////////////////////////////////////////////////////////////////////////////////
-->


<mod:findLike type="crew" limit="1">

<!-- 
*********************************************************************************************************
                   JUBJUB
*********************************************************************************************************
-->

	<mod-append:race name="jubjub">
		<essential>1</essential>
		<maxHealth>100</maxHealth>
		<animBase>human</animBase>
		<detectsLifeforms>true</detectsLifeforms>
		<isTelepathic>true</isTelepathic>
		<resistsMindControl>true</resistsMindControl>
		<cloneSpeedMultiplier>2.0</cloneSpeedMultiplier>
		<deathSounds>
			<deathSound>mantisDeath</deathSound>
		</deathSounds>
		<repairSounds animSoundFrame="5">
		  <repairSound>rockThud1</repairSound>
		  <repairSound>rockThud2</repairSound>
		  <repairSound>rockThud3</repairSound>
		</repairSounds>
		<powerEffect>
			<cooldown>30</cooldown>
			<jumpCooldown>full</jumpCooldown>
			<powerSounds>
				<powerSound>healBomb</powerSound>
			</powerSounds>
			<buttonText>SOUP</buttonText>
			<tooltip>[COOLDOWN: 30s]
				Drink Soup made by the Soup Dragon to return to full HP. </tooltip>
			<cooldownColor r="167" g="255" b="93" />
			<activateWhenReady>false</activateWhenReady>
			<selfHealth>1000</selfHealth>
		</powerEffect>	
	</mod-append:race>

<!-- 
*********************************************************************************************************
                   SOVIET
*********************************************************************************************************
-->

	<mod-append:race name="soviet">
		<maxHealth>100</maxHealth>
		<animBase>human</animBase>
		<deathSounds>
			<deathSound>death1</deathSound>
			<deathSound>death2</deathSound>
		</deathSounds>
		<passiveStatBoosts>
			<statBoost name="maxHealth">
				<boostType>MULT</boostType>
				<amount>1.25</amount>
				<shipTarget>CURRENT_ROOM</shipTarget>
				<crewTarget>ALLIES</crewTarget>
				<droneTarget>CREW</droneTarget>
				<affectsSelf>false</affectsSelf>
				<priority>0</priority>
				<whitelist>
					<soviet/>
				</whitelist>
			</statBoost>
			<statBoost name="repairSpeed">
				<boostType>MULT</boostType>
				<amount>1.25</amount>
				<shipTarget>CURRENT_ROOM</shipTarget>
				<crewTarget>ALLIES</crewTarget>
				<droneTarget>CREW</droneTarget>
				<affectsSelf>false</affectsSelf>
				<priority>0</priority>
				<whitelist>
					<soviet/>
				</whitelist>
			</statBoost>
		</passiveStatBoosts>
	</mod-append:race>

<!-- 
*********************************************************************************************************
                   HORSE
*********************************************************************************************************
-->

	<mod-append:race name="horse">
		<maxHealth>100</maxHealth>
		<controllable>true</controllable>
		<canMan>true</canMan>
		<canRepair>true</canRepair>
		<repairSpeed>0.5</repairSpeed>
		<fireRepairMultiplier>6.0</fireRepairMultiplier>
		<moveSpeedMultiplier>2.5</moveSpeedMultiplier>
		<damageMultiplier>1.5</damageMultiplier>
		<animBase>rock</animBase>
		<deathSounds>
			<deathSound>horseDeath</deathSound>
		</deathSounds>
		<shootingSounds>
			<shootingSound>rockThrow1</shootingSound>
			<shootingSound>rockThrow2</shootingSound>
			<shootingSound>rockThrow3</shootingSound>
		</shootingSounds>
	</mod-append:race>


<!-- 
*********************************************************************************************************
                   CRAB
*********************************************************************************************************
-->

	<mod-append:race name="crab">
		<controllable>true</controllable>
		<maxHealth>100</maxHealth>
		<moveSpeedMultiplier>1.5</moveSpeedMultiplier>
		<damageMultiplier>2</damageMultiplier>
		<repairSpeed>0.25</repairSpeed>
		<fireRepairMultiplier>1</fireRepairMultiplier>
		<fireDamageMultiplier>1</fireDamageMultiplier>
		<healSpeed>2.0</healSpeed>
		<animBase>mantis</animBase>
			<deathSounds>
			<deathSound>spiderDeath</deathSound>
		</deathSounds>
		<shootingSounds>
			<shootingSound>mantisSpit1</shootingSound>
			<shootingSound>mantisSpit2</shootingSound>
			<shootingSound>mantisSpit3</shootingSound>
		</shootingSounds>
		<powerEffect>
			<cooldown>20</cooldown>
			<req type="enemy">
				<enemyInRoom/>
			</req>
			<jumpCooldown>full</jumpCooldown>
			<powerSounds>
				<powerSound>multiexplosion</powerSound>
			</powerSounds>
			<buttonText>DIVORCE</buttonText>
			<tooltip>[COOLDOWN:20s DURATION:12s] Instantly divorces enemies in the room which stuns them for 5s. Crab cannot move during this time as he is finalising his paperwork. Lock and Load.</tooltip>
			<cooldownColor r="255" g="228" b="0"/>
			<friendlyFire>false</friendlyFire>
			<shipFriendlyFire>false</shipFriendlyFire>
			<stun>5</stun>
			<effectAnim>stun_bomb_detinate</effectAnim>
			<animFrame>8</animFrame>
			<temporaryEffect>
				<duration>12</duration>
				<cooldownColor r="255" g="242" b="140"/>
				<finishSounds>
					<finishSound>decloak</finishSound>
				</finishSounds>
				<canMove>false</canMove>
				<snapToSlot>true</snapToSlot>
				<validTarget>false</validTarget>
				<canRepair>false</canRepair>
			</temporaryEffect>
		</powerEffect>
	</mod-append:race>


</mod:findName>


<!-- 
///////////////////////////////////////////////////////////////////////////////////////////////////////
///////////////////////////////////////////////////////////////////////////////////////////////////////
///////////////////////////////////////////////////////////////////////////////////////////////////////
///////////////////////////////////////////////////////////////////////////////////////////////////////
					
					Events
					
///////////////////////////////////////////////////////////////////////////////////////////////////////
///////////////////////////////////////////////////////////////////////////////////////////////////////
///////////////////////////////////////////////////////////////////////////////////////////////////////
///////////////////////////////////////////////////////////////////////////////////////////////////////
-->

<mod:findLike type="events" limit="1">
    <mod-append:eventFile>sector_jub</mod-append:eventFile>
</mod:findLike>



<!--
////////////////////////////////////////////////////////////////////////////////////////////////////
////////////////////////////////////////////////////////////////////////////////////////////////////
//////////////AUGMENTS
////////////////////////////////////////////////////////////////////////////////////////////////////
////////////////////////////////////////////////////////////////////////////////////////////////////
-->


<augments>

	<aug name="GREEN_SOUP">
		<statBoosts>
			<statBoost name="maxHealth"><!-- <Increase Max Health by 20%> -->
				<boostType>MULT</boostType>
				<amount>1.20</amount>
				<shipTarget>ALL</shipTarget>
				<crewTarget>ALLIES</crewTarget>
				<droneTarget>CREW</droneTarget>
				<priority>0</priority>
			</statBoost>
			<statBoost name="powerRechargeMultiplier"><!-- <Increase JubJub Power Recharge by 33%> -->
				<boostType>MULT</boostType>
				<amount>1.333</amount>
				<shipTarget>ALL</shipTarget>
				<crewTarget>ALLIES</crewTarget>
				<droneTarget>CREW</droneTarget>
				<priority>0</priority>
				<whiteList>
					<jubjub/>
				</whiteList>
			</statBoost>
		</statBoosts>
	</aug>


</augments>

